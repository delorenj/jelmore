# Jelmore Environment Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# Core Settings
# =============================================================================

# Environment: development, staging, production
JELMORE_ENVIRONMENT=development

# Enable debug mode (verbose logging, stack traces)
JELMORE_DEBUG=false

# =============================================================================
# Redis Configuration
# =============================================================================

JELMORE_REDIS_HOST=localhost
JELMORE_REDIS_PORT=6379
JELMORE_REDIS_DB=0
# JELMORE_REDIS_PASSWORD=your_redis_password
JELMORE_REDIS_SSL=false

# =============================================================================
# RabbitMQ (Bloodbank) Configuration
# =============================================================================

JELMORE_RABBITMQ_HOST=localhost
JELMORE_RABBITMQ_PORT=5672
JELMORE_RABBITMQ_USERNAME=jelmore
JELMORE_RABBITMQ_PASSWORD=jelmore_dev
JELMORE_RABBITMQ_VHOST=/jelmore
JELMORE_RABBITMQ_SSL=false

# Event exchange configuration
JELMORE_RABBITMQ_EXCHANGE=jelmore.events
JELMORE_RABBITMQ_QUEUE_PREFIX=jelmore

# =============================================================================
# Provider Configuration
# =============================================================================

# Default provider: claude, gemini, codex
JELMORE_PROVIDER_DEFAULT=claude

# Provider timeout in seconds
JELMORE_PROVIDER_TIMEOUT_SECONDS=300

# Provider API Keys (set the ones you need)
# Note: These can also be set as ANTHROPIC_API_KEY, etc.
# JELMORE_PROVIDER_CLAUDE_API_KEY=sk-ant-...
# JELMORE_PROVIDER_GEMINI_API_KEY=...
# JELMORE_PROVIDER_CODEX_API_KEY=sk-...

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
JELMORE_LOG_LEVEL=INFO

# Log format: json, console
JELMORE_LOG_FORMAT=json

# Optional: Log to file
# JELMORE_LOG_FILE=/var/log/jelmore/jelmore.log

# =============================================================================
# Session Configuration
# =============================================================================

# Session TTL in hours (0 = no expiry)
JELMORE_SESSION_TTL_HOURS=24

# Maximum sessions per provider
JELMORE_SESSION_MAX_PER_PROVIDER=10

# Auto-cleanup expired sessions
JELMORE_SESSION_AUTO_CLEANUP=true

# =============================================================================
# XDG Directory Overrides (optional)
# =============================================================================

# These follow XDG Base Directory Specification
# Default: ~/.config/jelmore, ~/.local/share/jelmore, ~/.cache/jelmore

# XDG_CONFIG_HOME=~/.config
# XDG_DATA_HOME=~/.local/share
# XDG_CACHE_HOME=~/.cache
